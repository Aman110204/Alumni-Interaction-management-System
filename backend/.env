PORT=5000
NODE_ENV=development

# SECURITY: Generate a strong random 64+ char secret for production
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=alumni_connect_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRES_IN=7d

# Prisma requires DATABASE_URL (update password to match your Postgres setup)
DATABASE_URL="postgresql://postgres:aman@localhost:5432/alumni_connect"

# Comma-separated list of allowed frontend origins
# Add all college subdomains for local dev with lvh.me
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://skit.lvh.me:5173,http://nps.lvh.me:5173,http://christ.lvh.me:5173,http://rv.lvh.me:5173

# Multi-tenancy defaults (used when no subdomain is detected)
DEFAULT_COLLEGE_ID=skit
DEFAULT_COLLEGE_NAME=SKIT College of Engineering
